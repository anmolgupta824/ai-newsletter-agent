# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Required — OpenRouter API key (works with any LLM)
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required — Tavily search API key
# Free tier: 1000 searches/month at https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Required — Supabase credentials
# Get from your project at https://supabase.com/dashboard
# Or run locally: supabase start → http://127.0.0.1:54321
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Optional — Product Hunt API key
# Required for Product Hunt source. Get at https://www.producthunt.com/v2/oauth/applications
# Without this, the PH source will be skipped (5 sources still work)
PRODUCT_HUNT_API_KEY=

# Optional — GitHub personal access token
# Increases rate limit from 60 to 5000 req/hour
# Without this, GitHub source works but may hit rate limits
GITHUB_TOKEN=

# Optional — Branding (used in HTTP headers sent to OpenRouter)
SITE_URL=https://your-site.com
DIGEST_NAME=Your Digest Name
