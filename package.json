{
  "name": "ai-digest-agent",
  "version": "1.0.0",
  "description": "Build your own AI-curated weekly digest in 30 minutes",
  "type": "module",
  "scripts": {
    "digest:generate": "tsx --env-file=.env.local src/index.ts",
    "digest:status": "tsx --env-file=.env.local src/index.ts --status",
    "digest:health-check": "tsx --env-file=.env.local src/index.ts --health-check",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "openai": "^6.27.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "dotenv": "^17.3.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
